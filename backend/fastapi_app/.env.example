# Copy this file to .env and fill in real values.
# The .env file is gitignored and must never be committed.

# PostgreSQL connection (structured data: users, projects, aggregates)
DATABASE_URL=postgresql://dfuser:dfpass@localhost:5432/dataflow

# Secret used for signing tokens / sessions. Generate a strong random value.
SECRET_KEY=replace-with-a-strong-random-secret

# MongoDB connection (raw, high-volume event documents)
MONGO_URL=mongodb://localhost:27017
